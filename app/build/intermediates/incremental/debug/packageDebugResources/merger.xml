    </style></file><file path="/Users/nazmifaiz/AndroidStudioProjects/ElectricityBillApp/app/src/main/res/values/strings.xml" qualifiers=""><string name="app_name">Electric Bill Calculator</string><string name="history_title">Bill History</string><string name="detail_title">Bill Details</string><string name="about_title">About</string><string name="title_main">Monthly Electricity Bill Estimator</string><string name="label_month">Select Month</string><string name="label_units">Electricity Units Used (kWh)</string><string name="hint_units">Enter units between 1 - 1000</string><string name="label_rebate">Rebate Percentage (0% - 5%)</string><string name="btn_calculate">Calculate Bill</string><string name="btn_view_history">View Bill History</string><string name="btn_about">About</string><string name="result_title">Calculation Result</string><string name="label_total_charges">Total Charges:</string><string name="label_final_cost">Final Cost (After Rebate):</string><string name="instruction_text">Instructions: Select the billing month, enter your electricity usage in kWh (1-1000), choose a rebate percentage using the slider, then tap Calculate Bill to view your estimated charges. Results are saved automatically.</string><string name="error_units_empty">Please enter the number of units used.</string><string name="error_units_range">Units must be between 1 and 1000 kWh.</string><string name="error_units_invalid">Please enter a valid number for units.</string><string name="success_saved">Bill calculated and saved successfully!</string><string name="history_empty">No bill records found. Calculate a bill first.</string><string name="history_instruction">Tap on any record below to view full details, edit, or delete it.</string><string name="label_month_detail">Month:</string><string name="label_units_detail">Units Used (kWh):</string><string name="label_total_detail">Total Charges (RM):</string><string name="label_rebate_detail">Rebate (%):</string><string name="label_final_detail">Final Cost (RM):</string><string name="btn_edit">Edit / Update</string><string name="btn_delete">Delete</string><string name="btn_save_changes">Save Changes</string><string name="delete_confirm_title">Confirm Delete</string><string name="delete_confirm_message">Are you sure you want to delete this record? This action cannot be undone.</string><string name="update_success">Record updated successfully!</string><string name="delete_success">Record deleted successfully!</string><string name="student_name">Mohamad Nazmi Faiz bin Md Nasir</string><string name="student_id">2024827576</string><string name="student_class">NBCS2408A</string><string name="course_info">ICT602 - Mobile Technology</string><string name="app_description">Electric Bill Calculator is a mobile application designed to help users estimate their monthly electricity bill based on Malaysia\'s tiered electricity tariff system. Users can input the billing month, electricity units consumed (in kWh), and an applicable rebate percentage to calculate the total charges and final cost after rebate. All calculation records are stored locally and can be viewed, edited, or deleted via the Bill History page.</string><string name="copyright_text">© 2026 Nazmi Faiz All Rights Reserved.</string><string name="github_url">https://github.com/yourusername/ElectricityBillApp</string><string name="about_how_to_use_title">How to Use This App</string><string name="about_how_to_use">1. On the Home screen, select the billing month from the dropdown.\n2. Enter the number of electricity units used (kWh) - must be between 1 and 1000.\n3. Adjust the rebate percentage slider (0% to 5%) according to your eligibility.\n4. Tap \"Calculate Bill\" to view the Total Charges and Final Cost on the same page.\n5. The result is automatically saved to the local database.\n6. Tap \"View Bill History\" to see a list of all saved records (Month and Final Cost).\n7. Tap any record in the history list to view full details.\n8. In the Details page, you can edit the record\'s information and save changes, or delete the record entirely.\n9. Tap \"About\" from the home page to view app information and this guide again.</string></file><file name="ic_launcher" path="/Users/nazmifaiz/AndroidStudioProjects/ElectricityBillApp/app/src/main/res/mipmap-anydpi-v26/ic_launcher.xml" qualifiers="anydpi-v26" type="mipmap"/><file name="ic_launcher_round" path="/Users/nazmifaiz/AndroidStudioProjects/ElectricityBillApp/app/src/main/res/mipmap-anydpi-v26/ic_launcher_round.xml" qualifiers="anydpi-v26" type="mipmap"/></source></dataSet><dataSet aapt-namespace="http://schemas.android.com/apk/res-auto" config="debug$Generated" generated="true" ignore_pattern="!.svn:!.git:!.ds_store:!*.scc:.*:&lt;dir>_*:!CVS:!thumbs.db:!picasa.ini:!*~"><source path="/Users/nazmifaiz/AndroidStudioProjects/ElectricityBillApp/app/src/debug/res"/></dataSet><dataSet aapt-namespace="http://schemas.android.com/apk/res-auto" config="debug" generated-set="debug$Generated" ignore_pattern="!.svn:!.git:!.ds_store:!*.scc:.*:&lt;dir>_*:!CVS:!thumbs.db:!picasa.ini:!*~"><source path="/Users/nazmifaiz/AndroidStudioProjects/ElectricityBillApp/app/src/debug/res"/></dataSet><dataSet aapt-namespace="http://schemas.android.com/apk/res-auto" config="generated$Generated" generated="true" ignore_pattern="!.svn:!.git:!.ds_store:!*.scc:.*:&lt;dir>_*:!CVS:!thumbs.db:!picasa.ini:!*~"><source path="/Users/nazmifaiz/AndroidStudioProjects/ElectricityBillApp/app/build/generated/res/resValues/debug"/></dataSet><dataSet aapt-namespace="http://schemas.android.com/apk/res-auto" config="generated" generated-set="generated$Generated" ignore_pattern="!.svn:!.git:!.ds_store:!*.scc:.*:&lt;dir>_*:!CVS:!thumbs.db:!picasa.ini:!*~"><source path="/Users/nazmifaiz/AndroidStudioProjects/ElectricityBillApp/app/build/generated/res/resValues/debug"/></dataSet><mergedItems/></merger>